# ─────────────────────────────────────────────────────────────────────────────
# OnTimeCRM Backend — Environment Variables Reference
# Copy this file to .env and fill in real values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── docker-compose variable substitution (used by docker-compose.yml) ────────
# These flat names feed the ${VAR} placeholders in docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD
POSTGRES_DB=ontimecrm
JWT_KEY=REPLACE_WITH_A_RANDOM_SECRET_MINIMUM_32_CHARS
ADMIN_EMAIL=admin@ontimecrm.io
ADMIN_PASSWORD=REPLACE_WITH_A_STRONG_ADMIN_PASSWORD

# ── ASP.NET Core config keys (used when running `dotnet run` directly,
#    i.e. without docker-compose — these map 1:1 to appsettings.json) ────────

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase (production): Host=db.<project-ref>.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=<password>;SSL Mode=Require;Trust Server Certificate=true
# Local docker-compose: Host=localhost;Port=5434;Database=ontimecrm;Username=postgres;Password=postgres
ConnectionStrings__DefaultConnection=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Use a random secret in production.
Jwt__Key=
Jwt__Issuer=OnTimeCRM
Jwt__Audience=OnTimeCRM-Frontend
Jwt__ExpirationMinutes=480

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production: your Vercel domain.
Cors__AllowedOrigins__0=http://localhost:5173
# Cors__AllowedOrigins__1=https://your-app.vercel.app

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
# Created once on first startup if no companies exist.
AdminBootstrap__Email=admin@ontimecrm.io
AdminBootstrap__Password=Admin123!
AdminBootstrap__FullName=Administrador
AdminBootstrap__CompanyName=OnTimeCRM Demo
AdminBootstrap__BrandName=Stand Demo

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080

# ── Subscription Plans ────────────────────────────────────────────────────────
Subscription__Plans__Monthly__Price=15.00
Subscription__Plans__Annual__Price=149.00
Subscription__TrialDays=14
Subscription__GracePeriodDays=3

# ── Stripe (post-MVP — leave empty to stub) ───────────────────────────────────
Stripe__SecretKey=
Stripe__PublishableKey=
Stripe__WebhookSecret=

# ── Ifthenpay / MBWay + Multibanco (post-MVP — leave empty to stub) ───────────
Ifthenpay__MBWayKey=
Ifthenpay__MultibancoKey=
Ifthenpay__Entity=
Ifthenpay__CallbackSecretKey=
Ifthenpay__BaseUrl=https://ifthenpay.com/api
